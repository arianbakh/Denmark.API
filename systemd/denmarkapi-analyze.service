[Unit]
Description=DenmarkAPI smiley LLM analysis (gpt-oss-20b via local vLLM)
After=network-online.target docker.service

[Service]
Type=simple
User=arian
WorkingDirectory=/home/arian/Programming/DenmarkAPI
ExecStart=/home/arian/Programming/DenmarkAPI/.venv/bin/python -m denmarkapi.smiley.analyze --watch --concurrency 32
Restart=on-failure
RestartSec=30

[Install]
WantedBy=multi-user.target

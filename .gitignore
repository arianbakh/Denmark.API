# --- Python ---
.venv/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/

# --- Data & large files (NEVER commit) ---
data/                     # snapshots, parquet, state.db — all local working data
data/status.json          # live dashboard snapshot, rewritten every 2s — pure churn
# NOTE: data/control.json IS tracked (added with `git add -f`) so a fresh clone gets the
# pipeline defaults. A `!` un-ignore rule would NOT work here — git can't re-include a file
# under an excluded directory — but .gitignore never untracks an already-tracked file.
*.xlsx
*.xml
*.parquet
*.db
*.db-wal
*.db-shm
*.zip
*.gz
*.pdf

# --- Benchmark scratch ---
bench/io/

# --- Secrets (interim; proper secret mgmt is a backlog item) ---
secrets/

# --- Model weights (huge; pulled from HuggingFace) ---
models/

# --- Misc ---
get-pip.py
.DS_Store
*.log
scratchpad/

# --- Sample outputs for eyeballing (not committed; regenerate with overlay_pdf) ---
examples/
